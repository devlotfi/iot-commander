{
  "name": "esp-commander",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "terraform:init": "cd terraform && terraform init",
    "terraform:deploy": "wrangler deploy --dry-run --outdir dist && cd terraform && terraform apply",
    "migrate:local": "npx wrangler d1 migrations apply D1_DB --local",
    "migrate:remote": "npx drizzle-kit generate && npx drizzle-kit migrate",
    "cf-typegen": "wrangler types"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.14.7",
    "@types/node": "^25.6.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "~4.1.4",
    "wrangler": "^4.83.0"
  },
  "dependencies": {
    "@hono/zod-openapi": "^1.3.0",
    "@scalar/hono-api-reference": "^0.10.9",
    "@types/web-push": "^3.6.4",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.14",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  }
}
